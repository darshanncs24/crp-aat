import tkinter as tk
from tkinter import filedialog, messagebox
import cv2
from math import log10
from PIL import Image
import numpy as np
from cryptography.fernet import Fernet
import base64
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC

class SteganoApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Crypto-Stegano v2.0")
        self.root.geometry("400x500")
        
        tk.Label(root, text="Steganography Suite", font=('Arial', 16, 'bold')).pack(pady=10)
        
        tk.Label(root, text="Password (Secret Key):").pack()
        self.pass_entry = tk.Entry(root, show="*", width=30)
        self.pass_entry.pack(pady=5)
        
        tk.Label(root, text="Message (for Encoding):").pack()
        self.msg_text = tk.Text(root, height=5, width=40)
        self.msg_text.pack(pady=5)
        
        tk.Button(root, text="Encode & Save PNG", command=self.handle_encode, bg="#4CAF50", fg="white").pack(pady=10)
        tk.Button(root, text="Decode from Image", command=self.handle_decode, bg="#2196F3", fg="white").pack(pady=5)
        tk.Button(root,text="Test PSNR",command=self.calculate_psnr,bg="#FF9800",fg="white").pack(pady=5)

    def get_crypto_key(self, password):
        salt = b'constant_salt_2026' 
        kdf = PBKDF2HMAC(algorithm=hashes.SHA256(), length=32, salt=salt, iterations=100000)
        return base64.urlsafe_b64encode(kdf.derive(password.encode()))

    def get_shuffled_indices(self, width, height, password):
        """Hardcoded LCG Shuffler: No random.shuffle calls."""
        total_pixels = width * height
        indices = list(range(total_pixels))
        
        seed = sum(ord(c) for c in password)
        a = 1664525
        c = 1013904223
        m = 2**32
        
        curr = seed
        for i in range(total_pixels - 1, 0, -1):
            curr = (a * curr + c) % m
            j = curr % (i + 1)
            indices[i], indices[j] = indices[j], indices[i]
            
        return indices

    def handle_encode(self):
        img_path = filedialog.askopenfilename()
        if not img_path: return
        
        password = self.pass_entry.get()
        message = self.msg_text.get("1.0", tk.END).strip()
        
        if not password or not message:
            messagebox.showerror("Error", "Need password and message!")
            return

        key = self.get_crypto_key(password)
        f = Fernet(key)
        encrypted_data = f.encrypt(message.encode())
        bits = ''.join([format(b, '08b') for b in encrypted_data])
        
        img = Image.open(img_path).convert('RGB')
        pixels = np.array(img)
        h, w, _ = pixels.shape
        flat_pixels = pixels.reshape(-1, 3)
        
        shuffled_idx = self.get_shuffled_indices(w, h, password)
        
        bit_ptr = 0
        pixel_ptr = 0
        
        while bit_ptr < len(bits):
            idx_group = shuffled_idx[pixel_ptr : pixel_ptr + 3]
            pixel_ptr += 3
            
            rgb_block = []
            for idx in idx_group:
                rgb_block.extend(flat_pixels[idx])
            
            for i in range(8):
                if bit_ptr < len(bits):
                    bit = int(bits[bit_ptr])
                    # Parity Logic
                    if bit == 1 and rgb_block[i] % 2 == 0:
                        rgb_block[i] = min(255, rgb_block[i] + 1)
                    elif bit == 0 and rgb_block[i] % 2 != 0:
                        rgb_block[i] -= 1
                    bit_ptr += 1
            
            if bit_ptr >= len(bits):
                if rgb_block[8] % 2 == 0: rgb_block[8] = min(255, rgb_block[8] + 1)
            else:
                if rgb_block[8] % 2 != 0: rgb_block[8] -= 1
                
            for i, idx in enumerate(idx_group):
                flat_pixels[idx] = rgb_block[i*3 : i*3+3]

        new_img = Image.fromarray(flat_pixels.reshape(h, w, 3))
        save_path = filedialog.asksaveasfilename(defaultextension=".png")
        if save_path:
            new_img.save(save_path)
            messagebox.showinfo("Success", "Encoded successfully!")

    def handle_decode(self):
        img_path = filedialog.askopenfilename()
        if not img_path: return
        password = self.pass_entry.get()
        
        img = Image.open(img_path).convert('RGB')
        pixels = np.array(img)
        h, w, _ = pixels.shape
        flat_pixels = pixels.reshape(-1, 3)
        
        shuffled_idx = self.get_shuffled_indices(w, h, password)
        
        all_bits = ""
        pixel_ptr = 0
        
        while True:
            idx_group = shuffled_idx[pixel_ptr : pixel_ptr + 3]
            pixel_ptr += 3
            
            rgb_block = []
            for idx in idx_group:
                rgb_block.extend(flat_pixels[idx])
            
            for i in range(8):
                all_bits += str(rgb_block[i] % 2)
            
            if rgb_block[8] % 2 != 0:
                break
        
        try:
            byte_data = int(all_bits, 2).to_bytes((len(all_bits) + 7) // 8, 'big')
            key = self.get_crypto_key(password)
            f = Fernet(key)
            decrypted = f.decrypt(byte_data)
            self.msg_text.delete("1.0", tk.END)
            self.msg_text.insert("1.0", decrypted.decode())
        except Exception as e:
            messagebox.showerror("Error", "Decryption failed. Wrong password or corrupted image.")
    def calculate_psnr(self):
        original_path = filedialog.askopenfilename(
            title="Select Original Image"
        )

        if not original_path:
            return

        stego_path = filedialog.askopenfilename(
            title="Select Stego Image"
        )

        if not stego_path:
            return

        original = cv2.imread(original_path)
        stego = cv2.imread(stego_path)

        if original is None or stego is None:
            messagebox.showerror(
                "Error",
                "Unable to load images."
            )
            return

        if original.shape != stego.shape:
            messagebox.showerror(
                "Error",
                "Images must have same dimensions."
            )
            return

        mse = np.mean((original.astype(np.float64)
                    - stego.astype(np.float64)) ** 2)

        if mse == 0:
            psnr = float('inf')
        else:
            psnr = 10 * log10((255 ** 2) / mse)

        messagebox.showinfo(
            "PSNR Result",
            f"MSE : {mse:.6f}\nPSNR : {psnr:.2f} dB"
        )
if __name__ == "__main__":
    root = tk.Tk()
    app = SteganoApp(root)
    root.mainloop()